{
  "name": "claude-autonomous-workspace",
  "version": "0.1.0",
  "private": true,
  "description": "Autonomous Claude workspace — monorepo for web dashboard, FastAPI backend, Telegram bot, and news worker",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\"",
    "clean": "turbo run clean && rm -rf node_modules",
    "bootstrap": "bash infra/scripts/bootstrap.sh",
    "dev:up": "bash infra/scripts/dev-up.sh",
    "test:all": "bash infra/scripts/test-all.sh",
    "build:all": "bash infra/scripts/build-all.sh",
    "lint:all": "bash infra/scripts/lint-all.sh",
    "typecheck:all": "bash infra/scripts/typecheck-all.sh",
    "format:all": "bash infra/scripts/format-all.sh",
    "deliver:telegram": "bash infra/scripts/deliver-telegram-digest.sh"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  }
}
