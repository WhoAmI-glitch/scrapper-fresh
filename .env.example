# =============================================================================
# Claude Autonomous Workspace — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# =============================================================================

# --- Database ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/claude_workspace
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=claude_workspace

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here

# --- AI / LLM ---
ANTHROPIC_API_KEY=sk-ant-xxxxx
OPENAI_API_KEY=sk-xxxxx

# --- Web App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-random-secret-here
NEXTAUTH_URL=http://localhost:3000

# --- FastAPI Backend ---
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=generate-a-random-secret-here
API_CORS_ORIGINS=http://localhost:3000

# --- Worker ---
WORKER_POLL_INTERVAL=5
WORKER_BATCH_SIZE=10

# --- Bright Data (Proxy) ---
BRIGHTDATA_PROXY_URL=
BRIGHTDATA_API_KEY=

# --- News Sources ---
NEWS_RSS_FEEDS=
NEWS_SCRAPE_INTERVAL_MINUTES=60

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json

# --- Environment ---
NODE_ENV=development
