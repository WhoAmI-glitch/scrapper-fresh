# =============================================================================
# Scrapper Configuration — Russian Construction Lead Generator
# Copy to .env and fill in your values
# =============================================================================

# Database (required)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/scrapper

# Logging
LOG_LEVEL=INFO

# Fetch settings
FETCH_TIMEOUT=30
CONNECT_TIMEOUT=10
REQUEST_DELAY=2.0

# Worker
WORKER_POLL_INTERVAL=5
TASK_BATCH_SIZE=10
MAX_TASK_ATTEMPTS=3

# Bright Data (optional - for production scraping)
BRIGHTDATA_PROXY_URL=
BRIGHTDATA_API_KEY=

# Claude API (optional - for LLM fallback parsing)
CLAUDE_API_KEY=

# Yandex Maps API (optional - for discovery via Yandex Maps Places API)
YANDEX_API_KEY=

# Web UI auth
APP_USERNAME=admin
APP_PASSWORD=changeme

# Data directories
RAW_DATA_DIR=data/raw
EXPORT_DIR=data/exports
